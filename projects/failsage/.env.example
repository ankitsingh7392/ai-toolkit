# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── AI (Required for real analysis; leave blank for mock mode) ────────────────
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MOCK_MODE=false

# ── Notifications (optional) ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
JIRA_URL=
JIRA_TOKEN=
JIRA_PROJECT=QE

# ── Clustering ────────────────────────────────────────────────────────────────
CLUSTER_SIMILARITY_THRESHOLD=0.72

# ── Flaky detection ───────────────────────────────────────────────────────────
FLAKY_LOOKBACK_RUNS=10
FLAKY_FAIL_RATE_THRESHOLD=0.3
